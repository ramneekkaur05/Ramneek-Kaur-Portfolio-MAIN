---
const { title, subtitle, description } = Astro.props;
import { highlightTextParts } from "../../lib/highlightText";
---

<div class="flex">
  <div class="education__time">
    <span class="w-4 h-4 bg-primary block rounded-full mt-1"></span>
    <span class="education__line bg-primary block h-full w-[2px] translate-x-[7px]"></span>
  </div>
  <div class="experience__data bd-grid px-5">
    <h3 class="font-semibold mb-1">
      {highlightTextParts(title).map((part) =>
        part.kind ? <span class={`focus-${part.kind}`}>{part.text}</span> : part.text
      )}
    </h3>
    <span class="font-light text-sm">
      {highlightTextParts(subtitle).map((part) =>
        part.kind ? <span class={`focus-${part.kind}`}>{part.text}</span> : part.text
      )}
    </span>
    <p class="my-2 text-justify">
      {description
        ? highlightTextParts(description).map((part) =>
            part.kind ? <span class={`focus-${part.kind}`}>{part.text}</span> : part.text
          )
        : <slot />}
    </p>
  </div>
</div>
