---
import BaseLayout from "../layouts/BaseLayout.astro";
import Project3DCard from "../components/Project3DCard";

const projects = [
  {
    title: "Inner Compass Journaling App",
    img: "/projects/inner-compass-image.png",
    desc: "Full-stack journaling platform with guided prompts, mood analytics, and goal tracking to help users build consistent reflection habits.",
    url: "https://inner-compass-journal.vercel.app/",
    badge: "PRODUCT",
  },
  {
    title: "Audio RAG App",
    img: "/projects/RAG-over-audio-image.png",
    desc: "Retrieval-augmented audio Q&A pipeline: AssemblyAI transcription, LangChain orchestration, FAISS semantic search, and Gemini for answers, wrapped in Streamlit.",
    url: "https://github.com/ramneekkaur05/RAG_over_Audio",
    badge: "RAG",
  },
  {
    title: "Conversational AI Chatbot",
    img: "/projects/qa-chatbot-image.png",
    desc: "Context-aware chatbot leveraging session memory to preserve conversation flow and deliver more consistent responses.",
    url: "https://github.com/ramneekkaur05/Conversational_Chatbot",
    badge: "NLP",
  },
  {
    title: "Hand Gesture Volume Controller",
    img: "/projects/hand-gesture-image.png",
    desc: "Real-time hand tracking with OpenCV and MediaPipe, mapping gestures to system volume via Pycaw for a touchless control demo.",
    url: "https://github.com/ramneekkaur05/HandGesture_VolumeController",
    badge: "CV",
  },
];
---

<BaseLayout title = "Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects</div>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    {projects.map((project) => <Project3DCard client:load {...project} />)}
  </div>
</BaseLayout>
